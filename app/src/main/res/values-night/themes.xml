<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BakeryStore" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/caramel_light</item>
        <item name="colorPrimaryVariant">@color/caramel</item>
        <item name="colorOnPrimary">@color/text_chocolate</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/rose_pink_light</item>
        <item name="colorSecondaryVariant">@color/rose_pink_light</item>
        <item name="colorOnSecondary">@color/text_chocolate</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Global Font -->
        <item name="android:fontFamily">serif</item>
        <item name="fontFamily">serif</item>
        <item name="android:typeface">serif</item>
        <!-- Customize your theme here. -->
    </style>
</resources>