<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:padding="12dp"
                app:tint="@color/brown_text" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Hồ Sơ Của Bạn"
                android:textColor="@color/brown_text"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

        </LinearLayout>

        <!-- Section: Thông tin cá nhân -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:text="Thông tin cá nhân"
            android:textColor="@color/brown_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên"
                    android:textColor="@color/soft_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Nhập họ tên"
                    android:inputType="textPersonName"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/brown_text"
                    android:textSize="16sp"
                    android:fontFamily="serif" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email (Không thể sửa)"
                    android:textColor="@color/soft_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:inputType="textEmailAddress"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/soft_gray"
                    android:textSize="16sp"
                    android:fontFamily="serif" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại (Không thể sửa)"
                    android:textColor="@color/soft_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:inputType="phone"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/soft_gray"
                    android:textSize="16sp"
                    android:fontFamily="serif" />

                <Button
                    android:id="@+id/btnUpdateProfile"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_pink"
                    android:text="Cập nhật tên"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section: Đổi mật khẩu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="Bảo mật"
            android:textColor="@color/brown_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/edtOldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Mật khẩu hiện tại"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"
                    android:fontFamily="serif" />

                <EditText
                    android:id="@+id/edtNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Mật khẩu mới"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"
                    android:fontFamily="serif" />

                <EditText
                    android:id="@+id/edtConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Xác nhận mật khẩu mới"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:textSize="14sp"
                    android:fontFamily="serif" />

                <Button
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Đổi mật khẩu"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="40dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_button_pink"
                android:text="Lịch sử mua hàng"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:fontFamily="serif" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:fontFamily="serif" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>